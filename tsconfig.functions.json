{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "CommonJS",
    "moduleResolution": "node",
    "types": ["node"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "outDir": "./dist-functions",
    "rootDir": "./netlify/functions",
    "resolveJsonModule": true
  },
  "include": ["netlify/functions/**/*.ts"],
  "exclude": ["node_modules", "dist", "dist-functions"]
}
